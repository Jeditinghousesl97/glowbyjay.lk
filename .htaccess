# .htaccess Configuration
# This file tells the Apache server how to handle URLs.
# index.php is the homepage and front controller for routed pages.

RewriteEngine On
Options -Indexes

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain text/html text/xml text/css application/javascript application/x-javascript application/json application/xml image/svg+xml
</IfModule>

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType text/javascript "access plus 1 month"
</IfModule>

<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    <FilesMatch "\.(jpg|jpeg|png|gif|webp|svg)$">
        Header set Cache-Control "public, max-age=31536000"
    </FilesMatch>
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "public, max-age=2592000"
    </FilesMatch>
</IfModule>

# SEO endpoints
RewriteRule ^robots\.txt$ index.php?url=seo/robots [QSA,L]
RewriteRule ^sitemap\.xml$ index.php?url=seo/sitemap [QSA,L]

# 1. Block access to protected directories
RewriteRule ^(config|models|views|controllers)/ - [F,L]

# 2. Allow existing files and folders to be accessed directly
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# 3. Redirect everything else to index.php
# Using relative path for index.php so it works in /test/ OR /Ecom-CMS/
RewriteRule ^(.*)$ index.php?url=$1 [QSA,L]
